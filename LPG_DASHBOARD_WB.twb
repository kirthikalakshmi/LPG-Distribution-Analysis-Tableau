      <aliases enabled='yes' />
      <column caption='Delivery_Days' datatype='integer' name='[Calculation_0187525061132288]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Order_Date], [Delivery_Date])' />
      </column>
      <column caption='On-Time %' datatype='real' name='[Calculation_0187525074108417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Status] = &quot;On-Time&quot; THEN 1 ELSE 0 END) / COUNT([Order_ID])' />
      </column>
      <column caption='Domestic Cylinders' datatype='integer' name='[Calculation_0187525077700610]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Customer_Type] = &quot;Domestic&quot; THEN [Cylinders] ELSE 0 END)' />
      </column>
      <column caption='Commercial Cylinders' datatype='integer' name='[Calculation_0187525079953411]' role='measure' type='quantitative'>
